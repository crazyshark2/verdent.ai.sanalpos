      "group_id": "a5ed53cf-0378-43d7-ac57-9c8a1625db11",
      "content_snippet": "<?xml version=\"1.0\" encoding=\"utf-8\"?>\n<odoo>\n\n    <!-- Taksit Tan\u0131mlar\u0131 Tree View -->\n    <record id=\"sanal_pos_installment_tree\" model=\"ir.ui.view\">\n        <field name=\"name\">sanal.pos.installment.tree</field>\n        <field name=\"model\">sanal.pos.installment</field>\n        <field name=\"arch\" type=\"xml\">\n            <tree editable=\"bottom\">\n                <field name=\"provider_id\"/>\n                <field name=\"card_network\"/>\n                <field name=\"installment_count\"/>\n                <field name=\"interest_rate\"/>\n                <field name=\"min_amount\"/>\n                <field name=\"max_amount\"/>\n                <field name=\"is_active\" widget=\"boolean_toggle\"/>\n            </tree>\n        </field>\n    </record>\n\n    <!-- Taksit Tan\u0131mlar\u0131 Form View -->\n    <record id=\"sanal_pos_installment_form\" model=\"ir.ui.view\">\n        <field name=\"name\">sanal.pos.installment.form</field>\n        <field name=\"model\">sanal.pos.installment</field>\n        <field name=\"arch\" type=\"xml\">\n            <form>\n                <sheet>\n                    <group>\n                        <group>\n                            <field name=\"provider_id\"/>\n                            <field name=\"card_network\"/>\n                            <field name=\"installment_count\"/>\n                        </group>\n                        <group>\n                            <field name=\"interest_rate\"/>\n                            <field name=\"min_amount\"/>\n                            <field name=\"max_amount\"/>\n                            <field name=\"is_active\"/>\n                        </group>\n                    </group>\n                    <notebook>\n                        <page string=\"Kategori Bazl\u0131 Oranlar\">\n                            <field name=\"category_rate_ids\">\n                                <tree editable=\"bottom\">\n                                    <field name=\"category_id\"/>\n                                    <field name=\"interest_rate\"/>\n                                    <field name=\"is_active\" widget=\"boolean_toggle\"/>\n                                </tree>\n                            </field>\n                        </page>\n                    </notebook>\n                </sheet>\n            </form>\n        </field>\n    </record>\n\n    <!-- Taksit Tan\u0131mlar\u0131 Search View -->\n    <record id=\"sanal_pos_installment_search\" model=\"ir.ui.view\">\n        <field name=\"name\">sanal.pos.installment.search</field>\n        <field name=\"model\">sanal.pos.installment</field>\n        <field name=\"arch\" type=\"xml\">\n            <search>\n                <field name=\"provider_id\"/>\n                <field name=\"card_network\"/>\n                <filter name=\"active\" string=\"Aktif\" domain=\"[('is_active','=',True)]\"/>\n                <group expand=\"0\" string=\"Grupla\">\n                    <filter name=\"group_provider\" string=\"Provider\" context=\"{'group_by':'provider_id'}\"/>\n                    <filter name=\"group_network\" string=\"Kart A\u011f\u0131\" context=\"{'group_by':'card_network'}\"/>\n                </group>\n            </search>\n        </field>\n    </record>\n\n    <!-- Taksit Tan\u0131mlar\u0131 Action -->\n    <record id=\"action_sanal_pos_installment\" model=\"ir.actions.act_window\">\n        <field name=\"name\">Taksit Tan\u0131mlar\u0131</field>\n        <field name=\"res_model\">sanal.pos.installment</field>\n        <field name=\"view_mode\">tree,form</field>\n        <field name=\"context\">{'search_default_active': 1}</field>\n        <field name=\"help\" type=\"html\">\n            <p class=\"o_view_nocontent_smiling_face\">\n                Yeni taksit tan\u0131m\u0131 ekleyin\n            </p>\n            <p>\n                Her banka ve kart a\u011f\u0131 i\u00e7in taksit say\u0131s\u0131 ve faiz oranlar\u0131n\u0131 tan\u0131mlay\u0131n.\n            </p>\n        </field>\n    </record>\n\n</odoo>\n"
    }
  ],
