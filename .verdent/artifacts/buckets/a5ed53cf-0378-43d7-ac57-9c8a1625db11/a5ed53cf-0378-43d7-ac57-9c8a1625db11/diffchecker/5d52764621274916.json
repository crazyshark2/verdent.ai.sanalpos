      "group_id": "a5ed53cf-0378-43d7-ac57-9c8a1625db11",
      "content_snippet": "<?xml version=\"1.0\" encoding=\"utf-8\"?>\n<odoo>\n\n    <!-- BIN Veritaban\u0131 Tree View -->\n    <record id=\"sanal_pos_bin_tree\" model=\"ir.ui.view\">\n        <field name=\"name\">sanal.pos.bin.tree</field>\n        <field name=\"model\">sanal.pos.bin</field>\n        <field name=\"arch\" type=\"xml\">\n            <tree>\n                <field name=\"bin_number\"/>\n                <field name=\"bank_name\"/>\n                <field name=\"bank_code\"/>\n                <field name=\"card_network\"/>\n                <field name=\"card_type\"/>\n                <field name=\"card_category\"/>\n                <field name=\"is_active\" widget=\"boolean_toggle\"/>\n            </tree>\n        </field>\n    </record>\n\n    <!-- BIN Veritaban\u0131 Form View -->\n    <record id=\"sanal_pos_bin_form\" model=\"ir.ui.view\">\n        <field name=\"name\">sanal.pos.bin.form</field>\n        <field name=\"model\">sanal.pos.bin</field>\n        <field name=\"arch\" type=\"xml\">\n            <form>\n                <sheet>\n                    <group>\n                        <group>\n                            <field name=\"bin_number\"/>\n                            <field name=\"bank_name\"/>\n                            <field name=\"bank_code\"/>\n                        </group>\n                        <group>\n                            <field name=\"card_network\"/>\n                            <field name=\"card_type\"/>\n                            <field name=\"card_category\"/>\n                            <field name=\"is_active\"/>\n                        </group>\n                    </group>\n                </sheet>\n            </form>\n        </field>\n    </record>\n\n    <!-- BIN Veritaban\u0131 Search View -->\n    <record id=\"sanal_pos_bin_search\" model=\"ir.ui.view\">\n        <field name=\"name\">sanal.pos.bin.search</field>\n        <field name=\"model\">sanal.pos.bin</field>\n        <field name=\"arch\" type=\"xml\">\n            <search>\n                <field name=\"bin_number\"/>\n                <field name=\"bank_name\"/>\n                <field name=\"bank_code\"/>\n                <filter name=\"active\" string=\"Aktif\" domain=\"[('is_active','=',True)]\"/>\n                <group expand=\"0\" string=\"Grupla\">\n                    <filter name=\"group_bank\" string=\"Banka\"\n                            context=\"{'group_by':'bank_code'}\"/>\n                    <filter name=\"group_network\" string=\"Kart A\u011f\u0131\"\n                            context=\"{'group_by':'card_network'}\"/>\n                    <filter name=\"group_type\" string=\"Kart Tipi\"\n                            context=\"{'group_by':'card_type'}\"/>\n                </group>\n            </search>\n        </field>\n    </record>\n\n    <!-- BIN Veritaban\u0131 Action -->\n    <record id=\"action_sanal_pos_bin\" model=\"ir.actions.act_window\">\n        <field name=\"name\">BIN Veritaban\u0131</field>\n        <field name=\"res_model\">sanal.pos.bin</field>\n        <field name=\"view_mode\">tree,form</field>\n        <field name=\"context\">{'search_default_active': 1}</field>\n        <field name=\"help\" type=\"html\">\n            <p class=\"o_view_nocontent_smiling_face\">\n                BIN kayd\u0131 ekleyin\n            </p>\n            <p>\n                Kart numaras\u0131n\u0131n ilk 6 hanesine (BIN) g\u00f6re banka ve kart bilgilerini tan\u0131mlar.\n                Mod\u00fcl kurulumunda otomatik olarak ~1400 kay\u0131t y\u00fcklenir.\n            </p>\n        </field>\n    </record>\n\n</odoo>\n"
    }
