      "group_id": "a5ed53cf-0378-43d7-ac57-9c8a1625db11",
      "content_snippet": "<?xml version=\"1.0\" encoding=\"utf-8\"?>\n<odoo>\n\n    <!-- Payment Provider Form - Sanal POS Alanlar\u0131 -->\n    <record id=\"payment_provider_form_sanal_pos\" model=\"ir.ui.view\">\n        <field name=\"name\">payment.provider.form.sanal.pos</field>\n        <field name=\"model\">payment.provider</field>\n        <field name=\"inherit_id\" ref=\"payment.payment_provider_form\"/>\n        <field name=\"arch\" type=\"xml\">\n\n            <!-- Credentials Tab -->\n            <xpath expr=\"//page[@name='credentials']\" position=\"inside\">\n                <group name=\"sanal_pos_credentials\"\n                       invisible=\"code not in ('sanal_pos_garanti', 'sanal_pos_estv3', 'sanal_pos_payflex', 'sanal_pos_posnet')\">\n\n                    <group string=\"Banka Bilgileri\">\n                        <field name=\"sanal_pos_bank_name\"/>\n                        <field name=\"sanal_pos_gateway_type\" readonly=\"1\"/>\n                    </group>\n\n                    <group string=\"Kimlik Bilgileri\">\n                        <field name=\"sanal_pos_merchant_id\" password=\"True\"/>\n                        <field name=\"sanal_pos_terminal_id\"/>\n                        <field name=\"sanal_pos_store_key\" password=\"True\"/>\n                        <field name=\"sanal_pos_provision_user\"/>\n                        <field name=\"sanal_pos_provision_password\" password=\"True\"/>\n                    </group>\n\n                    <group string=\"\u0130ade Kimlik Bilgileri\" name=\"refund_credentials\">\n                        <field name=\"sanal_pos_refund_user\"/>\n                        <field name=\"sanal_pos_refund_password\" password=\"True\"/>\n                    </group>\n\n                    <group string=\"API URL'leri\">\n                        <field name=\"sanal_pos_api_url\"\n                               placeholder=\"https://sanalposprov.garantibbva.com.tr/VPServlet\"/>\n                        <field name=\"sanal_pos_api_url_test\"\n                               placeholder=\"https://sanalposprovtest.garantibbva.com.tr/VPServlet\"/>\n                        <field name=\"sanal_pos_3d_gate_url\"\n                               placeholder=\"https://sanalposprov.garantibbva.com.tr/servlet/gt3dengine\"/>\n                        <field name=\"sanal_pos_3d_gate_url_test\"\n                               placeholder=\"https://sanalposprovtest.garantibbva.com.tr/servlet/gt3dengine\"/>\n                    </group>\n\n                    <group string=\"\u00d6deme Ayarlar\u0131\">\n                        <field name=\"sanal_pos_3d_secure_active\"/>\n                        <field name=\"sanal_pos_payment_model\"/>\n                    </group>\n                </group>\n            </xpath>\n\n            <!-- Taksit Ayarlar\u0131 Tab -->\n            <xpath expr=\"//notebook\" position=\"inside\">\n                <page string=\"Taksit Ayarlar\u0131\" name=\"installment_config\"\n                      invisible=\"code not in ('sanal_pos_garanti', 'sanal_pos_estv3', 'sanal_pos_payflex', 'sanal_pos_posnet')\">\n                    <group>\n                        <group>\n                            <field name=\"sanal_pos_installment_active\"/>\n                            <field name=\"sanal_pos_max_installment\"\n                                   invisible=\"not sanal_pos_installment_active\"/>\n                        </group>\n                        <group>\n                            <field name=\"sanal_pos_min_installment_amount\"\n                                   invisible=\"not sanal_pos_installment_active\"/>\n                        </group>\n                    </group>\n                    <field name=\"sanal_pos_installment_config_ids\"\n                           invisible=\"not sanal_pos_installment_active\">\n                        <tree editable=\"bottom\">\n                            <field name=\"card_network\"/>\n                            <field name=\"installment_count\"/>\n                            <field name=\"interest_rate\"/>\n                            <field name=\"min_amount\"/>\n                            <field name=\"max_amount\"/>\n                            <field name=\"is_active\" widget=\"boolean_toggle\"/>\n                        </tree>\n                    </field>\n                </page>\n            </xpath>\n\n        </field>\n    </record>\n\n    <!-- Payment Transaction Form - Sanal POS Ek Alanlar -->\n    <record id=\"payment_transaction_form_sanal_pos\" model=\"ir.ui.view\">\n        <field name=\"name\">payment.transaction.form.sanal.pos</field>\n        <field name=\"model\">payment.transaction</field>\n        <field name=\"inherit_id\" ref=\"payment.payment_transaction_form\"/>\n        <field name=\"arch\" type=\"xml\">\n            <xpath expr=\"//sheet\" position=\"inside\">\n                <notebook invisible=\"provider_code not in ('sanal_pos_garanti', 'sanal_pos_estv3', 'sanal_pos_payflex', 'sanal_pos_posnet')\">\n                    <page string=\"Sanal POS Bilgileri\">\n                        <group>\n                            <group string=\"Banka Yan\u0131t\u0131\">\n                                <field name=\"sanal_pos_order_id\"/>\n                                <field name=\"sanal_pos_auth_code\"/>\n                                <field name=\"sanal_pos_rrn\"/>\n                                <field name=\"sanal_pos_transaction_id\"/>\n                                <field name=\"sanal_pos_host_ref_num\"/>\n                            </group>\n                            <group string=\"3D Secure\">\n                                <field name=\"sanal_pos_3d_status\"/>\n                                <field name=\"sanal_pos_md_status\"/>\n                                <field name=\"sanal_pos_eci\"/>\n                                <field name=\"sanal_pos_cavv\"/>\n                                <field name=\"sanal_pos_xid\"/>\n                            </group>\n                        </group>\n                        <group>\n                            <group string=\"Taksit Bilgileri\">\n                                <field name=\"sanal_pos_installment_count\"/>\n                                <field name=\"sanal_pos_installment_amount\"/>\n                                <field name=\"sanal_pos_total_with_interest\"/>\n                                <field name=\"sanal_pos_interest_rate\"/>\n                            </group>\n                            <group string=\"Kart Bilgileri\">\n                                <field name=\"sanal_pos_card_type\"/>\n                                <field name=\"sanal_pos_masked_pan\"/>\n                                <field name=\"sanal_pos_card_bank\"/>\n                            </group>\n                        </group>\n                        <group>\n                            <group string=\"\u0130ade/\u0130ptal\">\n                                <field name=\"sanal_pos_refund_amount\"/>\n                                <field name=\"sanal_pos_refund_date\"/>\n                                <field name=\"sanal_pos_cancel_date\"/>\n                                <field name=\"sanal_pos_original_tx_id\"/>\n                            </group>\n                            <group string=\"Hata Bilgileri\">\n                                <field name=\"sanal_pos_error_code\"/>\n                                <field name=\"sanal_pos_error_message\"/>\n                            </group>\n                        </group>\n                    </page>\n                    <page string=\"Ham Veri (Debug)\">\n                        <group>\n                            <field name=\"sanal_pos_raw_request\" widget=\"text\"/>\n                            <field name=\"sanal_pos_raw_response\" widget=\"text\"/>\n                        </group>\n                    </page>\n                </notebook>\n\n                <!-- \u0130ade ve \u0130ptal Butonlar\u0131 -->\n                <div class=\"oe_button_box\" name=\"sanal_pos_buttons\"\n                     invisible=\"provider_code not in ('sanal_pos_garanti', 'sanal_pos_estv3', 'sanal_pos_payflex', 'sanal_pos_posnet')\">\n                    <button name=\"action_sanal_pos_refund\" type=\"object\"\n                            string=\"\u0130ade\" class=\"oe_stat_button\"\n                            icon=\"fa-undo\"\n                            invisible=\"state != 'done'\"/>\n                    <button name=\"action_sanal_pos_cancel\" type=\"object\"\n                            string=\"\u0130ptal\" class=\"oe_stat_button\"\n                            icon=\"fa-times\"\n                            invisible=\"state != 'done'\"/>\n                    <button name=\"action_sanal_pos_query_status\" type=\"object\"\n                            string=\"Durum Sorgula\" class=\"oe_stat_button\"\n                            icon=\"fa-search\"/>\n                </div>\n            </xpath>\n        </field>\n    </record>\n\n</odoo>\n"
    }
  ],
  "source_file": "C:\\Users\\omerk\\odoo19-sanal-pos\\payment_sanal_pos\\views\\payment_provider_views.xml"
