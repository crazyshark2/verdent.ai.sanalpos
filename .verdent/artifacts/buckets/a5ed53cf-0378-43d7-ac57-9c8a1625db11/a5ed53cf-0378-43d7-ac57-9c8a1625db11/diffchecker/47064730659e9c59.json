      "session_id": "7f2d7a9a-f852-41cb-953d-bd51c19132df",
      "group_id": "a5ed53cf-0378-43d7-ac57-9c8a1625db11",
      "content_snippet": "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<templates xml:space=\"preserve\">\n\n    <!-- \u00d6deme Sayfas\u0131 Kart Formu -->\n    <t t-name=\"payment_sanal_pos.PaymentForm\">\n        <div class=\"sanal-pos-payment-form\">\n\n            <!-- Hata Mesaj\u0131 -->\n            <div t-if=\"state.error\" class=\"alert alert-danger mb-3\">\n                <i class=\"fa fa-exclamation-triangle me-1\"/>\n                <t t-esc=\"state.error\"/>\n            </div>\n\n            <!-- Kart Bilgileri -->\n            <div class=\"row g-3 mb-3\">\n                <!-- Kart Numaras\u0131 -->\n                <div class=\"col-12\">\n                    <label class=\"form-label fw-bold\">Kart Numaras\u0131</label>\n                    <div class=\"input-group\">\n                        <input type=\"text\" class=\"form-control\"\n                               placeholder=\"0000 0000 0000 0000\"\n                               maxlength=\"19\"\n                               t-att-value=\"state.cardNumber\"\n                               t-on-input=\"onCardNumberInput\"\n                               autocomplete=\"cc-number\"/>\n                        <span class=\"input-group-text\">\n                            <i t-att-class=\"state.cardNetworkIcon\"/>\n                        </span>\n                    </div>\n                    <!-- Banka Bilgisi -->\n                    <div t-if=\"state.bankInfo\" class=\"mt-1\">\n                        <small class=\"text-success\">\n                            <i class=\"fa fa-check-circle me-1\"/>\n                            <t t-esc=\"state.bankInfo.bank_name\"/>\n                        </small>\n                    </div>\n                </div>\n\n                <!-- Kart Sahibi -->\n                <div class=\"col-12\">\n                    <label class=\"form-label\">Kart Sahibi</label>\n                    <input type=\"text\" class=\"form-control\"\n                           placeholder=\"AD SOYAD\"\n                           t-model=\"state.cardHolder\"\n                           autocomplete=\"cc-name\"/>\n                </div>\n\n                <!-- Son Kullanma Tarihi -->\n                <div class=\"col-4\">\n                    <label class=\"form-label\">Ay</label>\n                    <select class=\"form-select\" t-model=\"state.expMonth\"\n                            autocomplete=\"cc-exp-month\">\n                        <option value=\"\">Ay</option>\n                        <option value=\"01\">01</option>\n                        <option value=\"02\">02</option>\n                        <option value=\"03\">03</option>\n                        <option value=\"04\">04</option>\n                        <option value=\"05\">05</option>\n                        <option value=\"06\">06</option>\n                        <option value=\"07\">07</option>\n                        <option value=\"08\">08</option>\n                        <option value=\"09\">09</option>\n                        <option value=\"10\">10</option>\n                        <option value=\"11\">11</option>\n                        <option value=\"12\">12</option>\n                    </select>\n                </div>\n                <div class=\"col-4\">\n                    <label class=\"form-label\">Y\u0131l</label>\n                    <select class=\"form-select\" t-model=\"state.expYear\"\n                            autocomplete=\"cc-exp-year\">\n                        <option value=\"\">Y\u0131l</option>\n                        <option value=\"2025\">2025</option>\n                        <option value=\"2026\">2026</option>\n                        <option value=\"2027\">2027</option>\n                        <option value=\"2028\">2028</option>\n                        <option value=\"2029\">2029</option>\n                        <option value=\"2030\">2030</option>\n                        <option value=\"2031\">2031</option>\n                        <option value=\"2032\">2032</option>\n                        <option value=\"2033\">2033</option>\n                        <option value=\"2034\">2034</option>\n                        <option value=\"2035\">2035</option>\n                    </select>\n                </div>\n                <div class=\"col-4\">\n                    <label class=\"form-label\">CVV</label>\n                    <input type=\"password\" class=\"form-control\"\n                           placeholder=\"***\" maxlength=\"4\"\n                           t-model=\"state.cvv\"\n                           autocomplete=\"cc-csc\"/>\n                </div>\n            </div>\n\n            <!-- Taksit Se\u00e7imi -->\n            <div t-if=\"state.installments.length > 1\" class=\"mb-3\">\n                <label class=\"form-label fw-bold\">Taksit Se\u00e7enekleri</label>\n                <div class=\"list-group\">\n                    <t t-foreach=\"state.installments\" t-as=\"inst\" t-key=\"inst.count\">\n                        <button type=\"button\"\n                                class=\"list-group-item list-group-item-action d-flex justify-content-between align-items-center\"\n                                t-att-class=\"{'active': state.selectedInstallment === inst.count}\"\n                                t-on-click=\"() => this.selectInstallment(inst.count)\">\n                            <div>\n                                <t t-if=\"inst.count === 1\">\n                                    <strong>Tek \u00c7ekim</strong>\n                                </t>\n                                <t t-else=\"\">\n                                    <strong><t t-esc=\"inst.count\"/> Taksit</strong>\n                                    <span t-if=\"inst.rate > 0\" class=\"text-muted ms-2\">\n                                        (+%<t t-esc=\"inst.rate.toFixed(1)\"/>)\n                                    </span>\n                                </t>\n                            </div>\n                            <div class=\"text-end\">\n                                <div><t t-esc=\"formatCurrency(inst.monthly)\"/>/ay</div>\n                                <small class=\"text-muted\">\n                                    Toplam: <t t-esc=\"formatCurrency(inst.total)\"/>\n                                </small>\n                            </div>\n                        </button>\n                    </t>\n                </div>\n            </div>\n\n            <!-- \u00d6deme Butonu -->\n            <button class=\"btn btn-primary btn-lg w-100\"\n                    t-on-click=\"onSubmit\"\n                    t-att-disabled=\"state.loading\">\n                <t t-if=\"state.loading\">\n                    <i class=\"fa fa-spinner fa-spin me-2\"/>\u0130\u015fleniyor...\n                </t>\n                <t t-else=\"\">\n                    <i class=\"fa fa-lock me-2\"/>G\u00fcvenli \u00d6deme Yap\n                </t>\n            </button>\n\n        </div>\n    </t>\n\n</templates>\n"
    }
  ],
  "source_file": "C:\\Users\\omerk\\odoo19-sanal-pos\\payment_sanal_pos\\static\\src\\xml\\payment_form.xml"
}