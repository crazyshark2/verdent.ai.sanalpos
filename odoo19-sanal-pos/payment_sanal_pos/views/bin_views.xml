<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- BIN Veritabanı Tree View -->
    <record id="sanal_pos_bin_tree" model="ir.ui.view">
        <field name="name">sanal.pos.bin.tree</field>
        <field name="model">sanal.pos.bin</field>
        <field name="arch" type="xml">
            <tree>
                <field name="bin_number"/>
                <field name="bank_name"/>
                <field name="bank_code"/>
                <field name="card_network"/>
                <field name="card_type"/>
                <field name="card_category"/>
                <field name="is_active" widget="boolean_toggle"/>
            </tree>
        </field>
    </record>

    <!-- BIN Veritabanı Form View -->
    <record id="sanal_pos_bin_form" model="ir.ui.view">
        <field name="name">sanal.pos.bin.form</field>
        <field name="model">sanal.pos.bin</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="bin_number"/>
                            <field name="bank_name"/>
                            <field name="bank_code"/>
                        </group>
                        <group>
                            <field name="card_network"/>
                            <field name="card_type"/>
                            <field name="card_category"/>
                            <field name="is_active"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- BIN Veritabanı Search View -->
    <record id="sanal_pos_bin_search" model="ir.ui.view">
        <field name="name">sanal.pos.bin.search</field>
        <field name="model">sanal.pos.bin</field>
        <field name="arch" type="xml">
            <search>
                <field name="bin_number"/>
                <field name="bank_name"/>
                <field name="bank_code"/>
                <filter name="active" string="Aktif" domain="[('is_active','=',True)]"/>
                <group expand="0" string="Grupla">
                    <filter name="group_bank" string="Banka"
                            context="{'group_by':'bank_code'}"/>
                    <filter name="group_network" string="Kart Ağı"
                            context="{'group_by':'card_network'}"/>
                    <filter name="group_type" string="Kart Tipi"
                            context="{'group_by':'card_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- BIN Veritabanı Action -->
    <record id="action_sanal_pos_bin" model="ir.actions.act_window">
        <field name="name">BIN Veritabanı</field>
        <field name="res_model">sanal.pos.bin</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                BIN kaydı ekleyin
            </p>
            <p>
                Kart numarasının ilk 6 hanesine (BIN) göre banka ve kart bilgilerini tanımlar.
                Modül kurulumunda otomatik olarak ~1400 kayıt yüklenir.
            </p>
        </field>
    </record>

</odoo>
